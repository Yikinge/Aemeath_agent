# 按你使用的 provider 填入对应的 Key，不用的可以留空

# Telegram 入口（Docker / python -m agent.main 都会读取）
TELEGRAM_BOT_TOKEN=
# 可选：逗号分隔的 Telegram 用户名白名单；留空 = 不限制
TELEGRAM_ALLOW_FROM=

# Docker 控制台端口
CONSOLE_PORT=8787
TZ=Asia/Shanghai

# 可选：容器访问 Telegram / LLM 需要走代理时填写。
# macOS Docker Desktop 里不要写 127.0.0.1，要用 host.docker.internal 指向宿主机。
# 示例：http://host.docker.internal:7890
TELEGRAM_PROXY_URL=
HTTP_PROXY=
HTTPS_PROXY=
ALL_PROXY=
NO_PROXY=localhost,127.0.0.1

# Anthropic (Claude 系列)
ANTHROPIC_API_KEY=

# OpenAI (GPT 系列)
OPENAI_API_KEY=

# DeepSeek
DEEPSEEK_API_KEY=

# Google (Gemini 系列)
GEMINI_API_KEY=

# Groq (高速推理，支持 LLaMA / Mixtral 等开源模型)
GROQ_API_KEY=

# SiliconFlow embedding（不填会退回本地哈希向量，仍可运行）
SILICONFLOW_API_KEY=
